<?xml version="1.0" encoding="UTF-8"?>
<!--
  CIMTool Logback Development Configuration
  ==========================================
  Development-only configuration for use with the Eclipse Debug launch
  configuration. Not bundled in the product export.

  SLF4J is wired to Logback via the io.ucaiug.slf4j.logback.binding fragment
  bundle, which attaches to slf4j.api and contributes the ServiceLoader
  registration that makes LogbackServiceProvider visible through slf4j.api's
  classloader. All three logging pipelines (SLF4J-native, JUL via
  SLF4JBridgeHandler, and Log4j 1.x via log4j-over-slf4j) therefore route
  through this configuration.

  In development mode (Platform.inDevelopmentMode() == true) CIMToolPlugin
  does NOT redirect System.out or System.err through the CIMTool.console.out /
  CIMTool.console.err JUL loggers — those streams go directly to the Eclipse
  Console view. The logger declarations below for CIMTool.console.out and
  CIMTool.console.err are therefore inactive in dev mode but are retained for
  reference and for any future dev-mode stream capture needs.

  The OnConsoleStatusListener below prints Logback's own startup diagnostics
  to System.err, confirming which config file was loaded and whether all
  appenders initialised correctly.
-->
<configuration>

    <!-- Logback startup diagnostics — confirms which config file was loaded -->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <!--
        CONSOLE appender — writes to the Eclipse Console view.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-7level [%logger{36}] %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        FILE appender — absolute path so you know exactly where it lands.
        Change this path to suit your environment.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>D:/CIMug-GIT-REPOS/release-2.3.1/logs/cimtool.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>D:/CIMug-GIT-REPOS/release-2.3.1/logs/cimtool-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>5</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-7level [%logger{36}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress UCanAccess and HSQLDB noise -->
    <logger name="net.ucanaccess" level="ERROR"/>
    <logger name="org.hsqldb" level="ERROR"/>

    <!-- Console stream capture loggers (inactive in dev mode — streams go direct to Eclipse Console view) -->
    <logger name="CIMTool.console.out" level="TRACE"/>
    <logger name="CIMTool.console.err" level="TRACE"/>

    <!-- Root at TRACE for development — both console and file -->
    <root level="TRACE">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
