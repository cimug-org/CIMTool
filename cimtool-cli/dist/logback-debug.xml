<?xml version="1.0" encoding="UTF-8"?>
<!--
  CIMTool CLI Debug Logback Configuration
  ==========================================
  Place this file alongside cimtool-cli.jar and activate it with:

    java -Dlogback.configurationFile=./logback-debug.xml -jar cimtool-cli.jar [options...]

  This overrides the production logback.xml bundled inside the JAR.

  Capturing all output to a log file
  =====================================
  Log output (warnings, errors, and debug messages) is written to stderr.
  Progress messages are written to stdout. The examples below capture both
  streams together so nothing is lost.

  Linux / macOS (bash) -> writes to file AND shows output on screen simultaneously:
    java -Dlogback.configurationFile=./logback-debug.xml -jar cimtool-cli.jar [options...] 2>&1 | tee debug.log

  Windows Command Prompt (cmd.exe) -> writes to file only (no simultaneous screen output):
    java -Dlogback.configurationFile=.\logback-debug.xml -jar cimtool-cli.jar [options...] > debug.log 2>&1

  Windows PowerShell -> writes to file AND shows output on screen simultaneously:
    java -Dlogback.configurationFile=.\logback-debug.xml -jar cimtool-cli.jar [options...] 2>&1 | Tee-Object -FilePath debug.log

  What this configuration enables
  ==================================
  TRACE on au.com.langdale.xmi:
    - Per-class registration during parseClasses() -- confirms whether extension
      namespace classes reach the internal objectIDs map.
    - Per-attribute row detail during parseAttributes() -- logs each attribute
      name, its Object_ID (domain class), its Classifier column value (the
      declared-type object ID from t_attribute), and whether the range resolved
      successfully.
    - Stereotype cache: logs count of t_xref entries loaded, each stereotype
      applied to a class by name (or a cache miss when no GUID entry is found).
      Key diagnostic: "Applying stereotype 'CIMDatatype' to 'RealEnergy'" vs
      "No stereotype entry found in cache for 'RealEnergy' (GUID='...')".
    - applyPrimitiveStereotype(): logs each class converted from rdf:type OWL.Class
      to rdf:type rdfs:Datatype. Key line: "Converted 'RealEnergy' to rdfs:Datatype".
      If this line is absent for a known CIMDatatype, the stereotype was not loaded.
    - Shadow class identification: logs every shadow class found by getShadowClasses()
      in both the bottom-up pass (showing which normative class it shadows) and the
      top-down <<ShadowExtension>> pass.
    - Shadow class merge: logs "Merging shadow class 'X' into normative class 'Y'"
      and for each property merged: its name, source shadow class, target normative
      class, and range type. Key line: "'highELimit' from 'ExtEmsBatteryUnit' into
      'BatteryUnit' (range: 'RealEnergy')".
    - classifyAttributes() in UMLInterpreter: logs each attribute's final
      classification as DatatypeProperty or ObjectProperty, with the range type and
      which branch fired. Key diagnostic:
        "classifyAttributes: 'highELimit' -> DatatypeProperty (range 'RealEnergy' has rdfs:Datatype)"
      confirms correct classification. Conversely:
        "classifyAttributes: 'highELimit' -> ObjectProperty (range 'RealEnergy' rdf:type=Class, has rdfs:Datatype=false)"
      confirms the stereotype was not applied to RealEnergy before classifyAttributes ran.
    - JDBC connection errors from EAPParser (UCanAccess/.eap) and QEAParser
      (SQLite/.qea).

  DEBUG on au.com.langdale.profiles.cl:
    - CLISchemaParser schema import events (orphaned classes, unused types) that
      are normally gated at INFO in production.

  ERROR on net.ucanaccess and org.hsqldb:
    - Preserves suppression of UCanAccess and HSQLDB reserved-word noise that is
      present in the production logback.xml.

  Root level WARN:
    - Keeps third-party library output (Saxon, Jena, etc.) quiet so the targeted
      au.com.langdale output above is not buried in noise. Change to DEBUG if
      broader framework-level diagnostics are also needed.
-->
<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-7level [%logger{36}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress UCanAccess JDBC driver reserved-word noise -->
    <logger name="net.ucanaccess" level="ERROR"/>

    <!-- Suppress HSQLDB verbose output (used internally by UCanAccess) -->
    <logger name="org.hsqldb" level="ERROR"/>

    <!--
        EA project file parsing, stereotype loading, shadow class processing,
        and CIM model interpretation and classification.
        Covers: AbstractEAProjectParsor, EAPParser, QEAParser,
                CIMInterpreterImpl, ShadowClassUtils, UMLInterpreter.
        TRACE enables per-attribute and per-class resolution detail, stereotype
        cache diagnostics, and per-property classification decisions.
    -->
    <logger name="au.com.langdale.xmi" level="TRACE"/>

    <!--
        CLISchemaParser schema import events. INFO surfaces model quality notices
        (unused classes, orphaned enumerations) that are suppressed at WARN in
        production.
    -->
    <logger name="au.com.langdale.profiles.cl" level="DEBUG"/>

    <!--
        Root logger at WARN.
        Keeps third-party library output (Saxon, Jena, etc.) quiet so the
        targeted au.com.langdale.xmi and au.com.langdale.profiles.cl output
        above is not buried in noise. Change to DEBUG here if broader
        framework-level diagnostics are also needed.
    -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
