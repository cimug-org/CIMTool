<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>au.com.langdale</groupId>
    <artifactId>cimtool-cli</artifactId>
    <version>2.3.0</version>
    <packaging>jar</packaging>

    <name>CIMTool CLI</name>
    <description>
        Standalone command-line interface for CIMTool profile transformations.
        Assembles cimutil.jar, kena.jar, and all vendored dependencies into a
        single executable uber JAR (cimtool-cli.jar) using Maven Shade.
        No Eclipse or OSGi runtime required.
    </description>

    <properties>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!--
        Local file repository containing all vendored JARs.

        Populated by running one of:
          Windows:   install-jars.bat
          Mac/Linux: chmod +x install-jars.sh && ./install-jars.sh

        These scripts invoke 'mvn install:install-file' for each JAR, placing
        it under lib-repo/ in the standard Maven repository layout. This
        approach avoids the deprecated system scope and resolves the m2e
        "must specify an absolute path" false-positive error in Eclipse.

        The lib-repo/ directory should be committed to source control so that
        any developer who has run an Eclipse PDE build can run 'mvn package'
        without needing to re-run the install script, as long as lib-repo/
        contents are current.

        Re-run the install script after each new CIMTool Eclipse PDE product
        export (e.g. after a new release build).
    -->
    <repositories>
		<repository>
		    <id>local-lib-repo</id>
		    <url>${project.baseUri}lib-repo</url>
		    <releases>
		        <enabled>true</enabled>
		        <updatePolicy>never</updatePolicy>
		    </releases>
		    <snapshots>
		        <enabled>false</enabled>
		    </snapshots>
		</repository>
    </repositories>

    <!--
        JAR Signing Profile
        ===================
        Activated by passing -Psign on the Maven command line:

            mvn clean package -Psign

        All sensitive keystore values are read from an external properties file
        that lives OUTSIDE the repository and is never committed to source control.
        The default expected location is the user's home directory:

            %USERPROFILE%\.cimtool\cimtool-signing.properties  (Windows)
            ~/.cimtool/cimtool-signing.properties               (Mac/Linux)

        Override the location by setting the system property at build time:

            mvn clean package -Psign -Dsigning.properties=C:\keys\my-signing.properties

        Required properties in cimtool-signing.properties:
            signing.keystore  = absolute path to the keystore file
            signing.alias     = alias of the key entry to sign with
            signing.storepass = keystore password
            signing.keypass   = key password (may be same as storepass)

        To generate a self-signed keystore see create-keystore.bat / create-keystore.sh.
        When a CA-issued certificate is obtained, replace the keystore file and update
        cimtool-signing.properties accordingly — no changes to pom.xml are required.
    -->
    <profiles>
        <profile>
            <id>sign</id>
            <build>
                <plugins>
                    <!--
                        properties-maven-plugin: Load signing credentials from the
                        external properties file before jarsigner runs.
                        The file path defaults to:
                          %USERPROFILE%\.cimtool\cimtool-signing.properties (Windows)
                          ~/.cimtool/cimtool-signing.properties               (Mac/Linux)
                        Override with: -Dsigning.properties=<absolute path>
                    -->
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>properties-maven-plugin</artifactId>
                        <version>1.2.1</version>
                        <executions>
                            <execution>
                                <id>load-signing-properties</id>
                                <phase>initialize</phase>
                                <goals>
                                    <goal>read-project-properties</goal>
                                </goals>
                                <configuration>
                                    <files>
                                        <file>${signing.properties}</file>
                                    </files>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jarsigner-plugin</artifactId>
                        <version>3.0.0</version>
                        <executions>

                            <execution>
                                <id>sign-uber-jar</id>
                                <!--
                                    Must run after the Shade plugin (package phase) has
                                    produced the uber JAR. jarPath directly targets the
                                    shaded uber JAR by name, bypassing the thin jar.
                                -->
                                <phase>package</phase>
                                <goals>
                                    <goal>sign</goal>
                                </goals>
                                <configuration>
                                    <!--
                                        Target the uber JAR directly by path. Using jarPath
                                        instead of archiveDirectory+includes ensures only
                                        cimtool-cli.jar is signed, not the thin jar.
                                    -->
                                    <archive>${project.build.directory}/cimtool-cli.jar</archive>

                                    <!-- Keystore details — loaded from external properties file -->
                                    <keystore>${signing.keystore}</keystore>
                                    <alias>${signing.alias}</alias>
                                    <storepass>${signing.storepass}</storepass>
                                    <keypass>${signing.keypass}</keypass>

                                    <!--
                                        Embed a trusted timestamp from DigiCert's free public
                                        TSA server. This ensures the signature remains
                                        verifiable after the signing certificate expires —
                                        critical when upgrading from self-signed to CA cert.
                                        Remove this element if building in an offline environment.
                                    -->
                                    <tsa>http://timestamp.digicert.com</tsa>

                                    <!--
                                        Verbose output shows each file signed and the
                                        certificate details — useful for confirming the
                                        correct key was used.
                                    -->
                                    <verbose>true</verbose>
                                </configuration>
                            </execution>

                            <execution>
                                <id>verify-uber-jar</id>
                                <!--
                                    Verify the signature immediately after signing to
                                    catch any keystore or configuration issues before
                                    the JAR is distributed.
                                -->
                                <phase>verify</phase>
                                <goals>
                                    <goal>verify</goal>
                                </goals>
                                <configuration>
                                    <archive>${project.build.directory}/cimtool-cli.jar</archive>
                                    <verbose>true</verbose>
                                </configuration>
                            </execution>

                        </executions>
                    </plugin>

                    <!--
                        maven-antrun-plugin: Deploy the signed uber JAR to dist/.

                        Runs in the install phase — after signing (package) and
                        signature verification (verify) have both completed
                        successfully. Copies the signed JAR to the dist/ directory
                        at the cimtool-cli project root, creating the directory if
                        it does not already exist. This is the distribution-ready
                        artifact for inclusion in official CIMTool releases.
                    -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>deploy-to-dist</id>
                                <phase>install</phase>
                                <goals>
                                    <goal>run</goal>
                                </goals>
                                <configuration>
                                    <target>
                                        <mkdir dir="${project.basedir}/dist"/>
                                        <copy
                                            file="${project.build.directory}/cimtool-cli.jar"
                                            todir="${project.basedir}/dist"
                                            overwrite="true"/>
                                        <echo message="Deployed: dist/cimtool-cli.jar"/>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                </plugins>
            </build>

            <!--
                Default path to the signing properties file.
                Override at build time with: -Dsigning.properties=<absolute path>
                The properties-maven-plugin reads this file during initialize phase
                and injects signing.keystore, signing.alias, signing.storepass,
                and signing.keypass as Maven properties.
            -->
            <properties>
                <signing.properties>${user.home}/.cimtool/cimtool-signing.properties</signing.properties>
            </properties>
        </profile>
    </profiles>

    <dependencies>

        <!-- ============================================================ -->
        <!-- CIMTool core modules — sourced from Eclipse PDE product export-->
        <!--                                                              -->
