        <!-- extracted by install-jars.bat from the JAR filenames in the  -->
        <!-- PDE export plugins/ directory. When a new CIMTool release is -->
        <!-- built, update these versions to match the new JAR filenames  -->
        <!-- before running install-jars.bat and mvn package.             -->
        <!-- ============================================================ -->

