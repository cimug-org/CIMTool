            </exclusions>
        </dependency>

        <!-- ============================================================ -->
        <!-- Kena/lib dependencies                                        -->
        <!--                                                              -->
        <!-- Intentionally omitted:                                       -->
        <!--   jena-2.6.3-tests.jar  — test-only artifact                -->
        <!--   iri-0.8-sources.jar   — source artifact                   -->
        <!--   junit-4.5.jar         — test framework                    -->
        <!--   slf4j-api-1.5.8.jar   — superseded by CIMUtil 1.7.36      -->
