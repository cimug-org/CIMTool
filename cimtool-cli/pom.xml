    <build>
        <plugins>

            <!--
                build-helper-maven-plugin: Add CIMUtil/builders/ and CIMUtil/import-reports/
                as resource roots.

                builders/: BuilderRegistry loads resources via getResourceAsStream("/builders.json")
                and getResourceAsStream("/" + xslFileName), meaning builders.json and all
                *.xsl files must reside at the classpath root of the uber JAR — NOT under
                a "builders/" subdirectory. Declaring the builders/ directory itself as the
                resource root achieves exactly this, so builders.json maps to /builders.json
                and e.g. xsd.xsl maps to /xsd.xsl in the uber JAR.

                import-reports/: The CLI references these resources via paths such as
                "/import-reports/puml/sparx-ea-style.puml" and "/import-reports/asciidoc".
                Unlike builders/, the import-reports/ directory structure must be preserved
                in the uber JAR, so targetPath is set to "import-reports" to place
                the contents under that subdirectory at the classpath root.
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-builders-resources</id>
                        <phase>generate-resources</phase>
                        <goals>
                            <goal>add-resource</goal>
                        </goals>
                        <configuration>
                            <resources>
                                <resource>
                                    <!--
                                        The builders/ directory from CIMUtil is added as the
                                        resource root. Its contents (builders.json, *.xsl,
                                        includes/, adoc-themes/) will be placed at the root
                                        of the uber JAR classpath.
                                    -->
                                    <directory>${basedir}/../CIMUtil/builders</directory>
                                    <filtering>false</filtering>
                                </resource>
                                <resource>
                                    <!--
                                        The import-reports/ directory from CIMUtil is added
                                        with targetPath="import-reports" so that its contents
                                        land under import-reports/ in the uber JAR classpath,
                                        matching the /import-reports/... resource paths used
                                        at runtime.
                                    -->
                                    <directory>${basedir}/../CIMUtil/import-reports</directory>
                                    <targetPath>import-reports</targetPath>
                                    <filtering>false</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                maven-shade-plugin: Assemble the uber JAR.

                Merges kena.jar, cimutil.jar, all vendored lib JARs, CIMUtil builders
                resources, and CIMUtil import-reports resources into a single
                self-contained executable JAR.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>

                            <!--
                                Security signature files must be stripped from all
                                contributing JARs, otherwise the JVM will refuse to
                                load the uber JAR with a SecurityException. MANIFEST.MF
                                files from each contributing JAR are also excluded since
                                the Shade plugin generates a merged one.
                            -->
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>META-INF/MANIFEST.MF</exclude>
                                    </excludes>
                                </filter>
                            </filters>

                            <transformers>

                                <!--
                                    Set the main class and embed version metadata
                                    in the uber JAR manifest.
                                -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>au.com.langdale.profiles.cl.CIMToolCLI</mainClass>
                                    <manifestEntries>
                                        <Implementation-Title>CIMTool CLI</Implementation-Title>
                                        <Implementation-Version>${project.version}</Implementation-Version>
                                        <Built-By>Maven Shade Plugin</Built-By>
                                    </manifestEntries>
                                </transformer>

                                <!--
                                    Saxon-HE 10.8 registers its TransformerFactory, XPathFactory,
                                    and other SPI implementations via META-INF/services entries.
                                    Without this transformer, shading would keep only one JAR's
                                    services file and XSLT processing would fail at runtime with
                                    a TransformerFactoryConfigurationError.
                                -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>

                                <!--
                                    Merge Apache LICENSE files from contributing JARs
                                    to avoid "duplicate entry" warnings and keep the
                                    uber JAR's META-INF/LICENSE coherent.
                                -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ApacheLicenseResourceTransformer"/>

                                <!--
                                    Append NOTICE files from all contributing JARs
                                    rather than overwriting, preserving attribution.
                                -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ApacheNoticeResourceTransformer">
                                    <addHeader>false</addHeader>
                                </transformer>

                            </transformers>

                            <!-- Output: cimtool-cli.jar in target/ -->
                            <finalName>cimtool-cli</finalName>

                            <!--
                                Do not generate a dependency-reduced POM alongside
                                the uber JAR. This project is a packaging artifact,
                                not intended for publication to a Maven repository.
                            -->
                            <createDependencyReducedPom>false</createDependencyReducedPom>

                        </configuration>
                    </execution>
                </executions>
            </plugin>

        </plugins>
    </build>

</project>
